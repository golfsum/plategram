# Plategram secrets. Copy this file to ".env" and fill in your own values.
#
# Anything prefixed EXPO_PUBLIC_ is read through process.env at build time.
#   Local:    "npx expo start" loads .env automatically.
#   expo.dev: create the same variables in your EAS project, e.g.
#             eas env:create --name EXPO_PUBLIC_GEMINI_API_KEY --value "..." --environment production
#
# Heads up: EXPO_PUBLIC_ values are bundled into the app and are not truly
# secret. For production, put the Gemini call behind a Cloud Function and keep
# the real key server side. These vars are fine for development and personal use.

# Google Gemini key for real photo analysis. Leave blank to stay in demo mode.
EXPO_PUBLIC_GEMINI_API_KEY=

# Firebase project that backs the online dashboard sync.
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_API_KEY=

# USDA FoodData Central, refines scanned macros against lab grade nutrition.
# Blank falls back to DEMO_KEY (very limited). Free key:
# https://fdc.nal.usda.gov/api-key-signup
EXPO_PUBLIC_FDC_API_KEY=

# recipeapi.io key (sk_live_...) for live recipe ideas in Plan your day.
# Blank keeps the offline curated library. Get a key at https://recipeapi.io
EXPO_PUBLIC_RECIPEAPI_KEY=

# ---- Firebase auth ----
# Firebase console > Project settings > General > Your apps (Web app config).
EXPO_PUBLIC_FIREBASE_APP_ID=            # "appId", e.g. 1:123456789012:web:abc123def456
EXPO_PUBLIC_FIREBASE_MSG_SENDER_ID=     # "messagingSenderId" (project number), e.g. 123456789012

# ---- Google sign-in (iOS) ----
# Add an iOS app in Firebase (bundle id com.nd82soft.plategram), download
# GoogleService-Info.plist, then copy these two values out of that file:
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=       # CLIENT_ID          (....apps.googleusercontent.com)
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=      # REVERSED_CLIENT_ID  (com.googleusercontent.apps....)

# ---- Apple sign-in ----
# No .env value needed. Uses the app bundle id + Sign in with Apple. Enable the
# Apple provider in Firebase Authentication and add the capability in Apple Developer.
